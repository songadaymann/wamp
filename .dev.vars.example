# Worker and local PartyKit server config. Frontend `VITE_*` vars belong in `.env.local`.

RESEND_API_KEY=
AUTH_EMAIL_FROM="Everybody's Platformer <onboarding@resend.dev>"
# Public app base URL used when constructing auth links from the Worker.
APP_BASE_URL="http://127.0.0.1:3000"
# Debug-only local mode: return the magic link in the API response instead of sending email.
AUTH_DEBUG_MAGIC_LINKS=1
# Dev-only reset route for wiping test data through the Worker UI button.
ENABLE_TEST_RESET=1
CHAT_OWNER_EMAILS=
PARTYKIT_HOST="127.0.0.1:1999"
PARTYKIT_PARTY="main"
PARTYKIT_INTERNAL_TOKEN=
ROOM_MINT_CHAIN_ID=84532
ROOM_MINT_CHAIN_NAME="Base Sepolia"
ROOM_MINT_RPC_URL=
ROOM_MINT_CONTRACT_ADDRESS=
ROOM_MINT_BLOCK_EXPLORER_URL="https://sepolia.basescan.org"
# Worker-side signer used for claimer-bound mint authorizations.
# This must match the contract's on-chain mintAuthority and should not be the owner key.
ROOM_MINT_AUTH_PRIVATE_KEY=

# Optional Play.fun integration for reward mode (`?pf=1`).
PLAYFUN_ENABLED=0
PLAYFUN_API_KEY=
PLAYFUN_SECRET_KEY=
PLAYFUN_GAME_ID=
PLAYFUN_BASE_URL="https://api.play.fun"
