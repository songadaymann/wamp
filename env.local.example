# Preferred Reown / WalletConnect Cloud project id for the frontend auth UI.
VITE_REOWN_PROJECT_ID=
# Optional legacy alias. If both are set, VITE_REOWN_PROJECT_ID wins.
# VITE_WALLET_CONNECT_PROJECT_ID=
# Optional: surface the reset button outside local Vite dev if you need it.
# VITE_ENABLE_TEST_RESET=1
VITE_ROOM_STORAGE_BACKEND=remote
# Optional: explicit PartyKit presence endpoint; defaults to 127.0.0.1:1999 in local Vite dev.
# VITE_PARTYKIT_HOST=127.0.0.1:1999
# VITE_PARTYKIT_PARTY=main
