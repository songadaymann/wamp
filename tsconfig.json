{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": ".tsbuild/app",
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/cloudflare/**/*", "partykit/**/*"],
  "references": [
    { "path": "./tsconfig.worker.json" },
    { "path": "./tsconfig.partykit.json" }
  ]
}
