{
  "name": "everybodys-platformer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "dev": "vite --strictPort --port 3000",
    "dev:frontend:local": "VITE_ROOM_API_BASE_URL='' vite --strictPort --port 3000",
    "dev:frontend:remote": "VITE_ROOM_API_BASE_URL='https://everybodys-platformer.novox-robot.workers.dev' vite --strictPort --port 3000",
    "dev:api": "wrangler dev",
    "dev:api:remote": "wrangler dev --remote",
    "dev:presence": "partykit dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "smoke:preview:readonly": "npx --yes --quiet -p playwright node scripts/preview_smoke_readonly.mjs",
    "contracts:build": "npm --prefix contracts run build",
    "contracts:test": "npm --prefix contracts run test",
    "contracts:deploy:base-sepolia": "npm --prefix contracts run deploy:base-sepolia",
    "db:safety:refresh:plan": "SAFETY_REFRESH_DRY_RUN=1 node scripts/refresh_safety_from_prod.mjs",
    "db:safety:refresh": "SAFETY_REFRESH_FROM_PROD=1 node scripts/refresh_safety_from_prod.mjs",
    "playfun:leaderboards:cleanup": "node scripts/cleanup_playfun_leaderboards.mjs",
    "cf:d1:migrate:local": "wrangler d1 migrations apply DB --local",
    "cf:d1:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "cf:d1:migrate:safety": "wrangler d1 migrations apply DB --env safety --remote",
    "cf:deploy": "npm run build && wrangler deploy",
    "cf:deploy:safety": "npm run build && wrangler deploy --env safety",
    "presence:deploy:safety": "partykit deploy --config partykit.safety.json"
  },
  "dependencies": {
    "@ethersproject/sha2": "^5.8.0",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-ethers": "^1.8.19",
    "ethers": "^6.16.0",
    "partysocket": "^1.1.16",
    "phaser": "^3.87.0",
    "resend": "^6.9.3",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "csstype": "^3.2.3",
    "partykit": "^0.0.115",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "wrangler": "^4.71.0"
  },
  "optionalDependencies": {
    "utf-8-validate": "^5.0.10"
  }
}
